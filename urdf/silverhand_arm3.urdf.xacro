<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="silverhand">
  <xacro:arg name="arm_color" default="0.80 0.80 0.82 1"/>

  <!-- Top-level wrapper that uses the third arm macro revision with the added covers
       and camera geometry. -->
  <xacro:include filename="$(find silverhand_arm_model)/urdf/silverhand_macro3.urdf.xacro"/>
  <xacro:silverhand_arm prefix="" color="$(arg arm_color)"/>
</robot>
